{
    "$schema": "https://schemas.wp.org/trunk/theme.json",
    "version": 2,
    "settings": {
        "layout": {
            "contentSize": "700px",
            "wideSize": "940px"
        },
        "color": {
            "defaultPalette": false,
            "palette": [
                { "name": "NABU Blau",        "slug": "nabu-blau",        "color": "#0068B4" },
                { "name": "NABU Dunkelblau",   "slug": "nabu-dunkelblau",  "color": "#003c68" },
                { "name": "NABU Grün",         "slug": "nabu-gruen",       "color": "#76b828" },
                { "name": "NABU Orange",       "slug": "nabu-orange",      "color": "#ef7c00" },
                { "name": "Hintergrund Beige", "slug": "nabu-hintergrund", "color": "#e3e2d4" },
                { "name": "Weiß",              "slug": "nabu-weiss",       "color": "#ffffff" },
                { "name": "Text Dunkel",       "slug": "nabu-text",        "color": "#333333" }
            ]
        },
        "typography": {
            "defaultFontSizes": false,
            "fontFamilies": [
                {
                    "name": "Source Sans Pro",
                    "slug": "source-sans-pro",
                    "fontFamily": "'Source Sans Pro', sans-serif"
                },
                {
                    "name": "System",
                    "slug": "system",
                    "fontFamily": "-apple-system, BlinkMacSystemFont, 'Segoe UI', Roboto, Oxygen, Ubuntu, sans-serif"
                }
            ],
            "fontSizes": [
                { "name": "Klein",     "slug": "small",   "size": "0.875rem" },
                { "name": "Normal",    "slug": "normal",  "size": "1rem"     },
                { "name": "Mittel",    "slug": "medium",  "size": "1.25rem"  },
                { "name": "Groß",      "slug": "large",   "size": "1.5rem"   },
                { "name": "Sehr groß", "slug": "x-large", "size": "2rem"     }
            ]
        },
        "spacing": {
            "padding":  true,
            "margin":   true,
            "blockGap": true,
            "units": ["px", "em", "rem", "%", "vw"]
        }
    },
    "styles": {
        "color": {
            "background": "#ffffff",
            "text": "#333333"
        },
        "typography": {
            "fontFamily": "var(--wp--preset--font-family--source-sans-pro)",
            "fontSize":   "1rem",
            "lineHeight": "1.6"
        },
        "elements": {
            "link": {
                "color": {
                    "text": "var(--wp--preset--color--nabu-blau)"
                },
                ":hover": {
                    "color": {
                        "text": "var(--wp--preset--color--nabu-dunkelblau)"
                    },
                    "typography": {
                        "textDecoration": "underline"
                    }
                }
            },
            "button": {
                "color": {
                    "background": "var(--wp--preset--color--nabu-blau)",
                    "text": "#ffffff"
                },
                "border": {
                    "radius": "0px"
                },
                ":hover": {
                    "color": {
                        "background": "var(--wp--preset--color--nabu-dunkelblau)"
                    }
                }
            },
            "heading": {
                "typography": {
                    "fontFamily": "var(--wp--preset--font-family--source-sans-pro)"
                }
            }
        }
    }
}
